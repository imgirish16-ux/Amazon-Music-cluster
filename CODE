df=pd.read_csv(r"C:\Users\GIRISH\Downloads\single_genre_artists.csv")
df.drop(columns=['name_artists','id_artists','id_songs','name_song','release_date'],inplace=True,errors='ignore')
X=['danceability','energy','loudness','speechiness','acousticness','instrumentalness','liveness','valence','tempo']
X=df[X]
model=StandardScaler()
scaled=model.fit_transform(X)
k_means=KMeans(n_clusters=4)
df['cluster']=k_means.fit_predict(scaled)
pca=PCA(n_components=2)
pca_comp=pca.fit_transform(scaled)
df['pca1']=pca_comp[:,0]
df['pca2']=pca_comp[:,1]
X=X.columns
cluster_profile = df.groupby('cluster')[X].mean()
inertia=[]
k_range=range(2,7)
for k in k_range:
    kmeans=KMeans(n_clusters=k)
    kmeans.fit(scaled)
    inertia.append(kmeans.inertia_)
plt.plot(k_range,inertia,marker='o')
plt.xlabel('K')
plt.ylabel('Inertia')
plt.show()
for k in range (2,7):
    kmeans=KMeans(n_clusters=k)
    labels=kmeans.fit_predict(scaled)
    score=silhouette_score(scaled,labels)
    print(f"k={k},s_score{score}")
plt.figure(figsize=(10,6))
sns.scatterplot(x='pca1', y='pca2', hue='cluster', data=df, palette='viridis')
plt.title('Clusters of Songs (PCA View)')
plt.show()
labels = df['cluster']

print("Silhouette Score:", silhouette_score(scaled, labels))
print("Davies Bouldin Score:", davies_bouldin_score(scaled, labels))

plt.figure(figsize=(12,6))
sns.heatmap(cluster_profile, annot=True, cmap='viridis')
plt.title('Cluster Feature Heatmap')
plt.show()
df.to_csv("Amazon_music_file",index=False)
